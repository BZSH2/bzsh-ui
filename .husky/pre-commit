#!/usr/bin/env sh
set -e
echo "🚀 开始代码检查..."

# 获取暂存的文件
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  echo "✅ 没有需要检查的文件"
  exit 0
fi

echo "📁 检查文件:"
echo "$STAGED_FILES" | sed 's/^/  /'

# 提交时只校验暂存区文件，兼顾速度和规则完整性。
# 开发态快速校验走 oxlint，完整的 ESLint + typecheck 放到 CI / 发布前执行。
echo "🔍 运行提交前代码检查和格式化..."
pnpm exec lint-staged

if [ $? -ne 0 ]; then
  echo "❌ 代码检查失败，请修复以上问题"
  exit 1
fi

echo "✅ 所有检查通过！"
