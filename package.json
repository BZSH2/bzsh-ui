{
  "name": "bzsh-ui-workspace",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "cz": "git add . && pnpm exec git-cz",
    "dev": "esno ./tooling/scripts/run-workspace-task.ts play:dev",
    "dev:docs": "esno ./tooling/scripts/run-workspace-task.ts docs:dev",
    "build": "esno ./tooling/scripts/run-root-task-group.ts build",
    "build:lib": "esno ./tooling/scripts/run-root-task-group.ts build:lib",
    "build:packages": "esno ./tooling/scripts/run-workspace-task.ts packages:build",
    "build:docs": "esno ./tooling/scripts/run-workspace-task.ts docs:build",
    "test": "esno ./tooling/scripts/run-root-task-group.ts test",
    "test:packages": "esno ./tooling/scripts/run-workspace-task.ts packages:test",
    "lint:staged": "lint-staged",
    "lint": "esno ./tooling/scripts/run-root-task-group.ts lint",
    "lint:packages": "esno ./tooling/scripts/run-workspace-task.ts packages:lint",
    "lint:root": "esno ./tooling/scripts/run-root-task-group.ts lint:root",
    "lint:eslint": "esno ./tooling/scripts/run-root-lint.ts eslint",
    "lint:eslint:fix": "esno ./tooling/scripts/run-root-lint.ts eslint --fix",
    "lint:stylelint": "esno ./tooling/scripts/run-root-lint.ts stylelint",
    "lint:stylelint:fix": "esno ./tooling/scripts/run-root-lint.ts stylelint --fix",
    "lint:fix": "esno ./tooling/scripts/run-root-task-group.ts lint:fix",
    "check": "esno ./tooling/scripts/run-root-task-group.ts check",
    "format": "prettier --write .",
    "typecheck": "esno ./tooling/scripts/run-root-task-group.ts typecheck",
    "typecheck:packages": "esno ./tooling/scripts/run-workspace-task.ts packages:typecheck",
    "typecheck:root": "vue-tsc -p tsconfig.json --noEmit",
    "sync:components": "esno ./tooling/scripts/sync-components.ts",
    "changeset": "changeset",
    "changeset:auto": "esno ./scripts/create-changeset.ts",
    "component": "esno ./scripts/create-component.ts",
    "module": "esno ./scripts/create-module.ts",
    "deleteC": "esno ./scripts/delete-component.ts",
    "utils": "esno ./scripts/create-utils.ts",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "ship": "esno ./scripts/release-manual.ts",
    "tag": "pnpm ship"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.5",
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.0.4",
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "eslint-config-prettier": "^10.1.5",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "eslint-plugin-vue": "^10.2.0",
    "esno": "^4.8.0",
    "git-cz": "^4.9.0",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.1.2",
    "postcss-html": "^1.8.0",
    "prettier": "^3.6.2",
    "sass": "^1.89.2",
    "stylelint": "^16.20.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recess-order": "^7.2.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitepress": "^1.6.3",
    "vitest": "^3.2.4",
    "vue": "^3.5.17",
    "vue-eslint-parser": "^10.1.3",
    "vue-tsc": "^3.0.1"
  }
}
