{
  "name": "bzsh-ui",
  "version": "0.1.12",
  "private": false,
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/types/ui/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/ui/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style/bzsh-ui.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "element-plus": "^2.14.2",
    "vue": "^3.5.17"
  },
  "dependencies": {
    "@bzsh-ui/components": "workspace:*",
    "@bzsh-ui/modules": "workspace:*",
    "@bzsh-ui/theme-chalk": "workspace:*",
    "@bzsh-ui/utils": "workspace:*"
  },
  "scripts": {
    "build": "vite build --config ./vite.config.ts",
    "lint": "eslint \"**/*.ts\"",
    "typecheck": "vue-tsc -p ../../tsconfig.json --noEmit"
  }
}
