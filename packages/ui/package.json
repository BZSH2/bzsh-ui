{
  "name": "bzsh-ui",
  "version": "0.1.5",
  "private": false,
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/types/ui/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/ui/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style/bzsh-ui.css"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "element-plus": "^2.14.2",
    "vue": "^3.5.17"
  },
  "scripts": {
    "build": "vite build --config ./vite.config.ts"
  }
}
