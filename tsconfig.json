{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "packages/**/*.ts",
    "packages/**/*.d.ts",
    "packages/**/*.mts",
    "packages/**/*.vue",
    "play/**/*.ts",
    "play/**/*.vue",
    "scripts/**/*.ts",
    "tooling/**/*.ts",
    "tooling/**/*.d.ts",
    "tests/**/*.ts",
    "vitest.config.ts",
    "eslint.config.mjs",
    "docs/.vitepress/config.ts"
  ]
}
